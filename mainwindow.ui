  <property name="styleSheet">
   <string notr="true">/* =========================================
   全局基础设置 (背景与字体)
========================================= */
QWidget {
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
    color: #333333;
    background-color: #F5F7FA; /* 极浅的蓝灰色，保护视力且显高级 */
}

/* =========================================
   题目展示区 (类似一张白纸)
========================================= */
QTextBrowser {
    background-color: #FFFFFF;
    border: 1px solid #E4E7ED;
    border-radius: 8px; /* 圆角边框 */
    padding: 20px;
    font-size: 16px;
}

/* =========================================
   单选题 / 多选题 (清爽的选中效果)
========================================= */
QRadioButton, QCheckBox {
    spacing: 12px;     /* 圆圈和文字的间距 */
    padding: 8px;
    font-size: 15px;
}

QRadioButton::indicator {
    width: 20px;
    height: 20px;
    border-radius: 10px; /* 让单选框变成完美的圆形 */
    border: 2px solid #DCDFE6;
    background-color: #FFFFFF;
}

QRadioButton::indicator:hover {
    border: 2px solid #409EFF; /* 鼠标悬停变蓝 */
}

QRadioButton::indicator:checked {
    border: 5px solid #409EFF; /* 选中时边框加粗，形成蓝圆点的视觉效果 */
    background-color: #FFFFFF;
}

/* =========================================
   普通按钮 (上一题 / 下一题)
========================================= */
QPushButton {
    background-color: #FFFFFF;
    border: 1px solid #DCDFE6;
    color: #606266;
    border-radius: 4px;
    padding: 8px 20px;
    font-weight: bold;
}

QPushButton:hover {
    color: #409EFF;
    border-color: #C6E2FF;
    background-color: #ECF5FF; /* 悬停时淡淡的蓝色背景 */
}

QPushButton:pressed {
    color: #3A8EE6;
    border-color: #3A8EE6;
}

/* =========================================
   高亮专属按钮 (交卷按钮)
   注意：在 Qt Designer 中需将此按钮的 objectName 改为 &quot;submitBtn&quot;
========================================= */
QPushButton#submitBtn {
    background-color: #409EFF; /* 主题蓝 */
    border: none;
    color: #FFFFFF;
}

QPushButton#submitBtn:hover {
    background-color: #66B1FF;
}

/* =========================================
   左侧答题卡方块按钮
   注意：在 Qt Designer 中需将这些按钮的 objectName 改为 &quot;gridBtn&quot;
========================================= */
QPushButton#gridBtn {
    background-color: #FFFFFF;
    border: 1px solid #EBEEF5;
    border-radius: 4px;
    min-width: 35px;
    min-height: 35px;
    padding: 0px;
}

QPushButton#gridBtn:hover {
    border-color: #409EFF;
}

/* 稍后我们可以用 C++ 代码给答过的题加上 &quot;answered&quot; 属性，让它变绿 */
QPushButton#gridBtn[state=&quot;answered&quot;] {
    background-color: #67C23A; /* 成功绿 */
    color: #FFFFFF;
    border: none;
}

/* =========================================
   倒计时警告文字
   注意：在 Qt Designer 中需将倒计时的标签 objectName 改为 &quot;timerLabel&quot;
========================================= */
QLabel#timerLabel {
    color: #F56C6C; /* 警示红 */
    font-size: 20px;
    font-weight: bold;
}

/* =========================================
   输入框 (学号、姓名、登录密码)
========================================= */
QLineEdit {
    background-color: #FFFFFF;
    border: 1px solid #DCDFE6; /* 默认灰色边框 */
    border-radius: 4px;        /* 轻微圆角 */
    padding: 8px 12px;         /* 让文字离边框有点距离，不拥挤 */
    selection-background-color: #409EFF; /* 选中文字时的背景色 */
    color: #606266;
    font-size: 14px;
}

QLineEdit:hover {
    border-color: #C0C4CC; /* 鼠标悬停时边框稍微加深 */
}

QLineEdit:focus {
    border-color: #409EFF; /* 获取焦点时，边框变成主题蓝色 */
    outline: none;         /* 去掉默认的蓝色外圈 */
}

/* 如果你设置了只读模式的输入框 */
QLineEdit:read-only {
    background-color: #F5F7FA;
    color: #909399;
    border-color: #E4E7ED;
}

/* 登录卡片的主体样式 */
#loginCard {
    background-color: #FFFFFF;      /* 纯白背景 */
    border: 1px solid #DCDFE6;      /* 浅灰色边框 */
    border-radius: 12px;            /* 圆角效果 */
}

/* 增加悬浮感（可选：鼠标放上去边框变蓝） */
#loginCard:hover {
    border: 1px solid #409EFF;
}

/* 在你的样式表里找到 QLabel 的部分，或者直接给那个标题设置 */
QLabel {
    background-color: transparent; /* 设置背景为透明 */
    border: none;                 /* 确保没有边框线 */
}

QMainWindow #centralwidget {
    border-image: url(:/pic/Login_menu.jpg);
}</string>
  </property>
